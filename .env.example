# LM Studio configuration
# Start LM Studio, load a chat model AND an embedding model, then enable the local server
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Model names — must match the model identifier shown in LM Studio
# Example chat model: "lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF"
CHAT_MODEL=your-chat-model-name-here

# Example embedding model: "nomic-ai/nomic-embed-text-v1.5-GGUF"
# Load this model in LM Studio before running indexer.py
EMBEDDING_MODEL=your-embedding-model-name-here

# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# Documents directory
DOCS_PATH=./docs
